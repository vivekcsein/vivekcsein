{
  // ─────────────────────────────────────────────────────────────
  // @vivekcsein | Hono × Vercel × Bun Backend tsconfig
  // Stack: Hono · Vercel Edge/Node · Bun · Zod
  // Fix: NodeNext → bundler moduleResolution (no .js extensions)
  // ─────────────────────────────────────────────────────────────
  "compilerOptions": {
    // ── Target & Runtime Libs ──────────────────────────────────
    "target": "ES2022",
    "lib": ["ES2022"], // Pure backend — NO DOM
    "module": "Preserve", // Let Bun/esbuild own the module format
    "moduleDetection": "force",
    "moduleResolution": "bundler", // FIX: no forced .js extensions, works with Bun + Vercel

    // ── Emit ──────────────────────────────────────────────────
    "outDir": "./dist",
    "rootDir": "./",
    "noEmit": false,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",

    // ── Module Interop ─────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "verbatimModuleSyntax": true, // Still enforces `import type` — tree-shaking safe
    "isolatedModules": true,
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true, // import './foo.ts' works in Bun natively

    // ── Strict Type Safety ─────────────────────────────────────
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,

    // ── Disabled (ESLint owns these) ───────────────────────────
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // ── Type Roots ─────────────────────────────────────────────
    "types": ["node", "bun-types"],

    // ── Path Aliases ───────────────────────────────────────────
    "paths": {
      "@/*": ["./src/*"],
      "@packages/*": ["./src/packages/*"],
      "@types/*": ["./src/types/*"]
    }
  },

  "include": ["src/**/*.ts", "src/**/*.d.ts", "index.ts"], // Ambient type declarations

  "exclude": ["node_modules", "dist", ".vercel", "coverage", "**/*.test.ts", "**/*.spec.ts"]
}
